  m_Script: {fileID: 11500000, guid: 83e0cec87ade7f64983a225cac04f5a1, type: 3}
  m_Name: Opening
  m_EditorClassIdentifier: 
  lines:
  - speaker: {fileID: 0}
    text: "\u2026Haven\u2019t seen your face before.\nYou\u2019re not from around
      here, are you?"
  - speaker: {fileID: 0}
    text: "you picked a bad time to wander in.\nThis town\u2026 it\u2019s rotting
      from the inside."
  - speaker: {fileID: 0}
    text: "It started a week ago. Dead don\u2019t stay buried anymore.\nSkeletons
      crawling out of the graveyard like they\u2019ve got unfinished business."
  - speaker: {fileID: 0}
    text: "I can\u2019t leave my post. Town still needs weapons.\nBut you? You look
      capable enough."
  - speaker: {fileID: 0}
    text: "Head to the graveyard just beyond the east gate.\nTake down as many as
      you can\u2014don\u2019t stop until the ground stays quiet.\n\nCome back to
      me when it\u2019s done."
  options: []
  offerQuestOnEnd: {fileID: 11400000, guid: 6f29db389da2b7445806c7e45f8d5801, type: 2}
